{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "enum": ["BRL", "USD", "EUR"], "description": "Default currency" },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "Custom categories for the user" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "darkMode": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "An expense or income record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the transaction" },
        "type": { "type": "string", "enum": ["expense", "income"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "rawMessage": { "type": "string", "description": "The original message sent by the user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "date"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the conversation history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "transactionId": { "type": "string", "description": "Optional link to a created transaction" }
      },
      "required": ["userId", "text", "sender", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial records"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "User's chat history"
    }
  }
}
